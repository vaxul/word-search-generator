{
  "permissions": {
    "defaultMode": "bypassPermissions",
    "allow": ["Bash", "WebFetch", "WebSearch"],
    "deny": [
      "Bash(rm -rf *)",
      "Bash(git push --force)",
      "Bash(git push --force *)",
      "Bash(git push -f)",
      "Bash(git push -f *)",
      "Bash(git reset --hard)",
      "Bash(git reset --hard *)",
      "Bash(git clean -f*)",
      "Bash(git branch -D *)",
      "Bash(git checkout .)",
      "Bash(git restore .)"
    ]
  }
}
